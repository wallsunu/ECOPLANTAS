@model EcoPlantas.Models.Reciclaje
@{
    ViewData["Title"] = "Detalle de Reciclaje";
}

<div class="container" style="max-width:480px;">
    <h2 class="mb-4" style="color:#2d6a4f;">♻️ Detalle de Reciclaje</h2>

    <div class="card shadow border-0">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-5">Material</dt>
                <dd class="col-sm-7">
                    <span class="badge" style="background-color:#52b788;font-size:1rem;">@Model.TipoMaterial</span>
                </dd>

                <dt class="col-sm-5">Cantidad</dt>
                <dd class="col-sm-7"><strong>@Model.Cantidad kg</strong></dd>

                <dt class="col-sm-5">Fecha</dt>
                <dd class="col-sm-7">@Model.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Reciclaje" asp-action="Index" class="btn btn-outline-secondary">← Volver al listado</a>
    </div>
</div>
