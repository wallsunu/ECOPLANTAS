<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoPlantas</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EcoPlantas.styles.css" asp-append-version="true" />
    <style>
        .navbar-brand { color: #2d6a4f !important; font-weight: bold; font-size: 1.4rem; }
        .nav-link:hover { color: #2d6a4f !important; }
        footer { background-color: #f8f9fa; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">🌿 EcoPlantas</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Catalogo" asp-action="Index">Catálogo</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contacto" asp-action="Index">Contacto</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reciclaje" asp-action="Index">Reciclaje</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("UsuarioEmail") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-success fw-bold">👤 @Context.Session.GetString("UsuarioEmail")</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger ms-2">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                    <span class="btn btn-sm" style="background-color:#2d6a4f;color:white;">Login</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (TempData["Exito"] != null)
    {
        <div class="container mt-2">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Exito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    @if (ViewData["FullWidth"] is true)
    {
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <footer class="border-top footer text-muted mt-4 py-3">
        <div class="container text-center">
            &copy; 2026 - EcoPlantas - Plantas Ecológicas y Orgánicas
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <!-- CHAT IA FLOTANTE -->
    <div id="aiButton"
        style="
        position:fixed;
        bottom:20px;
        right:20px;
        width:65px;
        height:65px;
        border-radius:50%;
        background:#2d6a4f;
        color:white;
        font-size:30px;
        display:flex;
        align-items:center;
        justify-content:center;
        cursor:pointer;
        z-index:9999;
        box-shadow:0 4px 12px rgba(0,0,0,.3);">
    🤖
    </div>

    <div id="aiChat"
        style="
        display:none;
        position:fixed;
        bottom:95px;
        right:20px;
        width:350px;
        background:white;
        border-radius:12px;
        padding:15px;
        z-index:9999;
        box-shadow:0 4px 20px rgba(0,0,0,.25);">

        <h5 class="mb-3">🌿 EcoPlantas IA</h5>

        <input
            id="preguntaIA"
            class="form-control"
            placeholder="Pregunta algo..." />

        <button
            class="btn btn-success w-100 mt-2"
            onclick="preguntarIA()">
            Preguntar
        </button>

        <hr />

        <div id="respuestaIA"
            style="
            max-height:250px;
            overflow-y:auto;">
        </div>
    </div>

    <script>

    document.getElementById("aiButton")
    .addEventListener("click", function () {

        let chat =
            document.getElementById("aiChat");

        if (chat.style.display === "none")
            chat.style.display = "block";
        else
            chat.style.display = "none";
    });

    async function preguntarIA() {

        let pregunta =
            document.getElementById("preguntaIA").value;

        if (!pregunta)
            return;

        document.getElementById("respuestaIA").innerHTML =
            "Pensando...";

        try {

            let response = await fetch('/api/ai/chat', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    pregunta: pregunta
                })
            });

            let data = await response.json();

            document.getElementById("respuestaIA").innerHTML =
                "<strong>Respuesta:</strong><br><br>" +
                data.respuesta;
        }
        catch {

            document.getElementById("respuestaIA").innerHTML =
                "Error al conectar con la IA.";
        }
    }

    </script>
<!-- FIN CHAT IA -->
</body>
</html>
