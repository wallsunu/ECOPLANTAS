@*
    Widget de chatbot IA flotante de EcoPlantas.
    Se incluye únicamente en páginas permitidas (ver condición en _Layout.cshtml).
    No modifica el flujo de IA: sigue llamando a POST /api/ai/chat.
*@
<div id="aiButton"
    style="
    position:fixed;
    bottom:20px;
    right:20px;
    width:65px;
    height:65px;
    border-radius:50%;
    background:#2d6a4f;
    color:white;
    font-size:30px;
    display:flex;
    align-items:center;
    justify-content:center;
    cursor:pointer;
    z-index:9999;
    box-shadow:0 4px 12px rgba(0,0,0,.3);">
🤖
</div>

<div id="aiChat"
    style="
    display:none;
    position:fixed;
    bottom:95px;
    right:20px;
    width:350px;
    background:white;
    border-radius:12px;
    padding:15px;
    z-index:9999;
    box-shadow:0 4px 20px rgba(0,0,0,.25);">

    <h5 class="mb-3">🌿 EcoPlantas IA</h5>

    <input
        id="preguntaIA"
        class="form-control"
        placeholder="Pregunta algo..." />

    <button
        class="btn btn-success w-100 mt-2"
        onclick="preguntarIA()">
        Preguntar
    </button>

    <hr />

    <div id="respuestaIA"
        style="
        max-height:250px;
        overflow-y:auto;">
    </div>
</div>

<script>

document.getElementById("aiButton")
.addEventListener("click", function () {

    let chat =
        document.getElementById("aiChat");

    if (chat.style.display === "none")
        chat.style.display = "block";
    else
        chat.style.display = "none";
});

async function preguntarIA() {

    let pregunta =
        document.getElementById("preguntaIA").value;

    if (!pregunta)
        return;

    document.getElementById("respuestaIA").innerHTML =
        "Pensando...";

    try {

        let response = await fetch('/api/ai/chat', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                pregunta: pregunta
            })
        });

        let data = await response.json();

        document.getElementById("respuestaIA").innerHTML =
            "<strong>Respuesta:</strong><br><br>" +
            data.respuesta;
    }
    catch {

        document.getElementById("respuestaIA").innerHTML =
            "Error al conectar con la IA.";
    }
}

</script>
