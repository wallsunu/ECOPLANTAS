@model EcoPlantas.Models.RegisterViewModel
@{
    ViewData["Title"] = "Crear cuenta";
}

<div class="container mt-5" style="max-width:420px;">
    <div class="text-center mb-4">
        <h2 style="color:#2d6a4f;">🌱 EcoPlantas</h2>
        <p class="text-muted">Crea tu cuenta vecinal</p>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-4">
            <form asp-action="Register" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold"></label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="tu@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-bold"></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Mínimo 6 caracteres" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repite tu contraseña" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-lg" style="background-color:#2ECC71;color:white;font-weight:600;">
                        Crear cuenta
                    </button>
                </div>
            </form>
        </div>
    </div>

    <p class="text-center text-muted mt-3 small">
        ¿Ya tienes cuenta?
        <a asp-controller="Auth" asp-action="Login" style="color:#2d6a4f;font-weight:600;">Inicia sesión</a>
    </p>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
