@model List<EcoPlantas.Models.Usuario>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<h2 class="text-center mt-4">🏆 Ranking de Recicladores</h2>

<div class="container mt-4">
    <div class="row justify-content-center">

        @{
            int posicion = 1;
        }

        @foreach (var usuario in Model)
        {
            var medalla = "";
            var colorCard = "";

            if (posicion == 1)
            {
                medalla = "🥇";
                colorCard = "border-warning";
            }
            else if (posicion == 2)
            {
                medalla = "🥈";
                colorCard = "border-secondary";
            }
            else if (posicion == 3)
            {
                medalla = "🥉";
                colorCard = "border-danger";
            }

            <div class="col-md-4 mb-4">
                <div class="card shadow leaderboard-card @colorCard">
                    <div class="card-body text-center">

                        <h4 class="card-title">
                            @medalla @usuario.Correo
                        </h4>

                        <p class="text-muted">Usuario registrado</p>

                        <h3 class="points">
                            ⭐ @usuario.Puntos puntos
                        </h3>

                        <span class="position-badge">#@posicion</span>

                    </div>
                </div>
            </div>

            posicion++;
        }

    </div>
</div>    posicion++;
