@inject IConfiguration Configuration
@{
    ViewData["Title"] = "EcoPlantas - Cieneguilla";
    ViewData["FullWidth"] = true;
    var email = Context.Session.GetString("UsuarioEmail");
    var logueado = email != null;

    // La API key se lee de configuración (variable de entorno Mapa__ApiKey).
    // Nunca se escribe fija aquí ni en appsettings.json.
    var googleMapsApiKey = Configuration["Mapa:ApiKey"] ?? "";
    var googleMapsConfigurado = !string.IsNullOrWhiteSpace(googleMapsApiKey);
}

<!-- HERO -->
<section class="eco-hero">
    <div class="container text-center py-5">
        <div class="mb-3">
            <span class="badge eco-badge-ods px-3 py-2">ODS 12 · Producción y Consumo Responsables</span>
        </div>
        <h1 class="eco-hero-title">Recicla, Gana Puntos<br>y Canjea Plantas</h1>
        <p class="eco-hero-sub">
            Conecta tu reciclaje con el camión municipal de Cieneguilla<br>
            y recibe plantas ecológicas para tu hogar.
        </p>
        <div class="d-flex flex-wrap gap-3 justify-content-center mt-4">
            <a asp-controller="Catalogo" asp-action="Index" class="btn eco-btn-primary btn-lg px-4">
                Ver catálogo
            </a>
            @if (logueado)
            {
                <a asp-controller="Reciclaje" asp-action="Crear" class="btn eco-btn-outline btn-lg px-4">
                    Registrar reciclaje
                </a>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="btn eco-btn-outline btn-lg px-4">
                    Registrar reciclaje
                </a>
            }
            <a asp-controller="Contacto" asp-action="Index" class="btn btn-outline-light btn-lg px-4">
                Contacto
            </a>
        </div>
    </div>
</section>

<!-- CÓMO FUNCIONA -->
<section class="py-5 bg-white">
    <div class="container">
        <h2 class="text-center eco-section-title mb-5">¿Cómo funciona?</h2>
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <div class="eco-step-card h-100 p-4">
                    <div class="eco-step-num">1</div>
                    <div class="eco-step-icon mb-3">🔑</div>
                    <h6 class="fw-bold">Regístrate o<br>inicia sesión</h6>
                    <p class="text-muted small mb-0">Crea tu cuenta vecinal en segundos</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="eco-step-card h-100 p-4">
                    <div class="eco-step-num">2</div>
                    <div class="eco-step-icon mb-3">🚛</div>
                    <h6 class="fw-bold">Entrega tu<br>reciclaje</h6>
                    <p class="text-muted small mb-0">Al camión municipal en tu zona</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="eco-step-card h-100 p-4">
                    <div class="eco-step-num">3</div>
                    <div class="eco-step-icon mb-3">⚖️</div>
                    <h6 class="fw-bold">Registra los<br>kilos reciclados</h6>
                    <p class="text-muted small mb-0">Ingresa el tipo y cantidad en la app</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="eco-step-card h-100 p-4">
                    <div class="eco-step-num">4</div>
                    <div class="eco-step-icon mb-3">🌱</div>
                    <h6 class="fw-bold">Gana puntos y<br>canjea plantas</h6>
                    <p class="text-muted small mb-0">Elige tu planta del catálogo ecológico</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PANEL VECINO + PANEL MUNICIPAL -->
<section class="py-5" style="background:#f0faf4;">
    <div class="container">
        <div class="row g-4 align-items-stretch">

            <!-- Panel vecino -->
            <div class="col-md-6">
                <div class="eco-panel h-100 p-4">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <span style="font-size:1.6rem;">👤</span>
                        <h5 class="mb-0 fw-bold" style="color:#2d6a4f;">Tu progreso vecinal</h5>
                    </div>

                    @if (logueado)
                    {
                        <p class="text-muted small">Sesión activa: <strong>@email</strong></p>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small fw-bold">Total reciclado</span>
                            <span class="small text-success fw-bold">Ver en Reciclaje</span>
                        </div>
                        <div class="progress mb-3" style="height:18px;border-radius:10px;">
                            <div class="progress-bar" role="progressbar"
                                 style="width:40%;background:linear-gradient(90deg,#2ECC71,#2d6a4f);">
                                40%
                            </div>
                        </div>
                        <p class="text-muted small mb-4">Necesitas 25 kg más para canjear tu próxima planta</p>
                        <a asp-controller="Reciclaje" asp-action="Crear" class="btn eco-btn-primary w-100">
                            ♻️ Registrar reciclaje ahora
                        </a>
                    }
                    else
                    {
                        <p class="text-muted mb-3">Inicia sesión para ver tu progreso y registrar reciclaje.</p>
                        <div class="progress mb-3" style="height:18px;border-radius:10px;">
                            <div class="progress-bar" role="progressbar"
                                 style="width:0%;background:linear-gradient(90deg,#2ECC71,#2d6a4f);">
                            </div>
                        </div>
                        <p class="text-muted small mb-4">— kg reciclados · — puntos disponibles</p>
                        <a asp-controller="Auth" asp-action="Login" class="btn eco-btn-primary w-100">
                            Iniciar sesión
                        </a>
                    }
                </div>
            </div>

            <!-- Panel municipal -->
            <div class="col-md-6">
                <div class="eco-panel h-100 p-4">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <span style="font-size:1.6rem;">🏛️</span>
                        <h5 class="mb-0 fw-bold" style="color:#8E44AD;">Panel Municipal · Cieneguilla</h5>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="eco-stat-card text-center p-3">
                                <div class="eco-stat-num" style="color:#8E44AD;">3</div>
                                <div class="text-muted small">Condominios con<br>recojo pendiente</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="eco-stat-card text-center p-3">
                                <div class="eco-stat-num" style="color:#2d6a4f;">120 kg</div>
                                <div class="text-muted small">Peso total<br>pendiente</div>
                            </div>
                        </div>
                    </div>
                    <div class="eco-map-hint d-flex align-items-center gap-2 p-3">
                        <span style="font-size:1.6rem;">🗺️</span>
                        <span class="small text-muted mb-0">
                            Revisa los <strong>puntos ecológicos cercanos</strong> en el mapa interactivo más abajo.
                        </span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- PUNTOS ECOLÓGICOS · GOOGLE MAPS API -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="text-center mb-4">
            <h2 class="eco-section-title mb-2">Puntos ecológicos cercanos</h2>
            <p class="text-muted mb-0">
                Encuentra centros de acopio y reciclaje en Lima y Cieneguilla.
                Mapa impulsado por <strong>Google Maps API</strong>.
            </p>
        </div>

        <!-- Buscador de dirección (Geocoding API) -->
        <div class="row justify-content-center mb-4">
            <div class="col-lg-8">
                <div class="input-group eco-buscador">
                    <input id="buscarDireccion" type="text" class="form-control"
                           placeholder="Buscar dirección o distrito, por ejemplo Cieneguilla" />
                    <button id="btnBuscar" class="btn eco-btn-primary px-4" type="button">Buscar</button>
                </div>
                <div id="buscarMensaje" class="small mt-2 d-none"></div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Mapa -->
            <div class="col-lg-8">
                <div id="mapaEcoPlantas" class="eco-mapa"></div>
                <div id="mapaMensaje" class="eco-mapa-mensaje @(googleMapsConfigurado ? "d-none" : "")">
                    <div style="font-size:2.5rem;">🗺️</div>
                    <div class="small mt-1">El mapa no está disponible por el momento.<br>Verifica la configuración de Google Maps.</div>
                </div>
            </div>

            <!-- Lista de tarjetas de puntos ecológicos -->
            <div class="col-lg-4">
                <div id="listaPuntos" class="eco-puntos-lista">
                    <div class="text-muted small text-center py-4">Cargando puntos ecológicos…</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ODS 12 -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-md-2 text-center">
                <div class="eco-ods-badge mx-auto">
                    <div style="font-size:2.2rem;">⚙️</div>
                    <div class="fw-bold" style="font-size:.75rem;letter-spacing:.5px;">ODS 12</div>
                </div>
            </div>
            <div class="col-md-7">
                <h4 class="fw-bold mb-2" style="color:#2d6a4f;">Producción y Consumo Responsables</h4>
                <p class="text-muted mb-0">
                    EcoPlantas se alinea con el Objetivo de Desarrollo Sostenible 12 de la ONU.
                    Incentivamos el reciclaje domiciliario en Cieneguilla conectando a los vecinos
                    con el sistema municipal, reduciendo residuos y promoviendo una economía circular
                    a través del canje de plantas ecológicas.
                </p>
            </div>
            <div class="col-md-3 text-center">
                <div class="d-flex flex-column gap-2">
                    <div class="eco-ods-stat">
                        <span class="fw-bold" style="color:#2ECC71;font-size:1.4rem;">↓ 30%</span>
                        <span class="text-muted small d-block">residuos al relleno</span>
                    </div>
                    <div class="eco-ods-stat">
                        <span class="fw-bold" style="color:#2d6a4f;font-size:1.4rem;">100%</span>
                        <span class="text-muted small d-block">plantas orgánicas</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA FINAL -->
<section class="eco-cta py-5">
    <div class="container text-center">
        <h3 class="text-white fw-bold mb-3">¿Listo para empezar a reciclar?</h3>
        <p class="text-white-50 mb-4">Únete a los vecinos de Cieneguilla que ya cuidan el planeta.</p>
        <a asp-controller="Reciclaje" asp-action="Index" class="btn btn-light btn-lg px-5 me-2" style="color:#2d6a4f;font-weight:600;">
            Ver reciclajes
        </a>
        <a asp-controller="Catalogo" asp-action="Index" class="btn btn-outline-light btn-lg px-5">
            Ver catálogo
        </a>
    </div>
</section>

@section Scripts {
    <script>
        // Centro por defecto: Cieneguilla, Lima.
        const ECO_MAP_CENTER = { lat: -12.1167, lng: -76.8167 };
        const ECO_MAPS_CONFIGURADO = @(googleMapsConfigurado ? "true" : "false");

        // Estado compartido del módulo de mapa.
        let ecoMapa = null;
        let ecoInfoWindow = null;
        let ecoMarkers = [];
        let ecoPuntos = [];
        let ecoMarkerBusqueda = null;

        // Escapa texto para evitar inyección al construir HTML.
        function ecoEscape(t) {
            const d = document.createElement("div");
            d.textContent = t ?? "";
            return d.innerHTML;
        }

        // Carga los puntos desde la API y pinta las tarjetas. Siempre se ejecuta,
        // exista o no Google Maps configurado.
        async function ecoCargarPuntos() {
            const lista = document.getElementById("listaPuntos");
            try {
                const resp = await fetch("/api/mapa/puntos");
                if (!resp.ok) throw new Error("respuesta no OK");
                ecoPuntos = await resp.json();

                if (!ecoPuntos.length) {
                    lista.innerHTML = '<div class="text-muted small text-center py-4">No hay puntos ecológicos disponibles.</div>';
                    return;
                }

                lista.innerHTML = ecoPuntos.map((p, i) => `
                    <div class="eco-punto-card" data-index="${i}" role="button" tabindex="0">
                        <div class="eco-punto-nombre">📍 ${ecoEscape(p.nombre)}</div>
                        <div class="eco-punto-dir">${ecoEscape(p.direccion)}</div>
                        <div class="eco-punto-desc">${ecoEscape(p.descripcion)}</div>
                    </div>`).join("");

                lista.querySelectorAll(".eco-punto-card").forEach(card => {
                    const idx = parseInt(card.getAttribute("data-index"), 10);
                    card.addEventListener("click", () => ecoCentrarEnPunto(idx));
                    card.addEventListener("keypress", e => { if (e.key === "Enter") ecoCentrarEnPunto(idx); });
                });
            } catch (e) {
                lista.innerHTML = '<div class="alert alert-warning small mb-0">No se pudieron cargar los puntos ecológicos en este momento.</div>';
            }
        }

        // Centra el mapa en un punto y abre su InfoWindow (si el mapa está disponible).
        function ecoCentrarEnPunto(i) {
            const p = ecoPuntos[i];
            if (!p) return;
            if (!ecoMapa) return; // sin mapa, la tarjeta es solo informativa
            const pos = { lat: p.latitud, lng: p.longitud };
            ecoMapa.panTo(pos);
            ecoMapa.setZoom(15);
            const marker = ecoMarkers[i];
            if (marker && ecoInfoWindow) {
                ecoInfoWindow.setContent(ecoContenidoInfo(p));
                ecoInfoWindow.open(ecoMapa, marker);
            }
            document.getElementById("mapaEcoPlantas").scrollIntoView({ behavior: "smooth", block: "center" });
        }

        function ecoContenidoInfo(p) {
            return `<div style="max-width:220px;">
                        <strong>${ecoEscape(p.nombre)}</strong><br>
                        <span class="text-muted">${ecoEscape(p.direccion)}</span><br>
                        <small>${ecoEscape(p.descripcion)}</small>
                    </div>`;
        }

        // Callback que invoca la Google Maps JavaScript API al terminar de cargar.
        async function initMapaEcoPlantas() {
            const contenedor = document.getElementById("mapaEcoPlantas");
            const mensaje = document.getElementById("mapaMensaje");
            try {
                ecoMapa = new google.maps.Map(contenedor, {
                    center: ECO_MAP_CENTER,
                    zoom: 12,
                    mapTypeControl: false,
                    streetViewControl: false
                });
                ecoInfoWindow = new google.maps.InfoWindow();

                // Asegura que los puntos estén cargados antes de crear marcadores.
                if (!ecoPuntos.length) await ecoCargarPuntos();

                ecoMarkers = ecoPuntos.map(p => {
                    const marker = new google.maps.Marker({
                        position: { lat: p.latitud, lng: p.longitud },
                        map: ecoMapa,
                        title: p.nombre
                    });
                    marker.addListener("click", () => {
                        ecoInfoWindow.setContent(ecoContenidoInfo(p));
                        ecoInfoWindow.open(ecoMapa, marker);
                    });
                    return marker;
                });
            } catch (e) {
                contenedor.classList.add("d-none");
                mensaje.classList.remove("d-none");
            }
        }

        // Buscador de dirección → /api/mapa/geocode
        async function ecoBuscarDireccion() {
            const input = document.getElementById("buscarDireccion");
            const msg = document.getElementById("buscarMensaje");
            const direccion = (input.value || "").trim();

            msg.className = "small mt-2 text-muted";
            if (!direccion) { msg.textContent = "Escribe una dirección o distrito para buscar."; return; }
            if (!ecoMapa) { msg.textContent = "El mapa no está disponible por el momento."; return; }

            msg.textContent = "Buscando…";
            try {
                const resp = await fetch("/api/mapa/geocode?direccion=" + encodeURIComponent(direccion));
                const data = await resp.json();
                if (data && data.exito && data.latitud != null && data.longitud != null) {
                    const pos = { lat: data.latitud, lng: data.longitud };
                    ecoMapa.panTo(pos);
                    ecoMapa.setZoom(15);
                    if (ecoMarkerBusqueda) ecoMarkerBusqueda.setMap(null);
                    ecoMarkerBusqueda = new google.maps.Marker({
                        position: pos,
                        map: ecoMapa,
                        title: data.direccionFormateada || direccion,
                        animation: google.maps.Animation.DROP
                    });
                    ecoInfoWindow.setContent(
                        `<div style="max-width:220px;"><strong>${ecoEscape(data.direccionFormateada || direccion)}</strong></div>`);
                    ecoInfoWindow.open(ecoMapa, ecoMarkerBusqueda);
                    msg.className = "small mt-2 text-success";
                    msg.textContent = "Ubicación encontrada: " + (data.direccionFormateada || direccion);
                } else {
                    msg.className = "small mt-2 text-warning";
                    msg.textContent = "No encontramos esa dirección. Intenta con otra referencia.";
                }
            } catch (e) {
                msg.className = "small mt-2 text-warning";
                msg.textContent = "No se pudo realizar la búsqueda en este momento.";
            }
        }

        // Si la API de Google falla al autenticar, mostramos el mensaje amable.
        function gm_authFailure() {
            document.getElementById("mapaEcoPlantas").classList.add("d-none");
            document.getElementById("mapaMensaje").classList.remove("d-none");
        }

        document.addEventListener("DOMContentLoaded", () => {
            ecoCargarPuntos();
            const btn = document.getElementById("btnBuscar");
            const input = document.getElementById("buscarDireccion");
            if (btn) btn.addEventListener("click", ecoBuscarDireccion);
            if (input) input.addEventListener("keypress", e => { if (e.key === "Enter") ecoBuscarDireccion(); });
        });
    </script>

    @if (googleMapsConfigurado)
    {
        @* IMPORTANTE: la key de Google Maps JavaScript API es visible en el navegador por diseño.
           Restríngela en Google Cloud Console por HTTP referrer (dominio) y por APIs permitidas
           (Maps JavaScript API + Geocoding API). La key viene de configuración, nunca fija en código. *@
        <script async
                src="https://maps.googleapis.com/maps/api/js?key=@googleMapsApiKey&callback=initMapaEcoPlantas&loading=async">
        </script>
    }
}
